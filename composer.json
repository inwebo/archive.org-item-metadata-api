{
    "name": "inwebo/archive.org-item-metadata-api",
    "description": "PHP client library for the Internet Archive Item Metadata API",
    "type": "library",
    "license": "MIT",
    "version": "1.0.0",
    "keywords": [
        "internet-archive",
        "archive.org",
        "metadata",
        "json-patch",
        "wayback-machine"
    ],
    "require": {
        "php": ">=8.1",
        "symfony/http-client": "^6.0|^7.0|^8.0",
        "symfony/contracts": "^3.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0|^11.0",
        "symfony/http-client": "^6.0|^7.0|^8.0",
        "friendsofphp/php-cs-fixer": "^3.91",
        "phpstan/phpstan": "^2.1"
    },
    "autoload": {
        "psr-4": {
            "Inwebo\\ItemMetaData\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Inwebo\\ItemMetaData\\Tests\\": "tests/"
        }
    },
    "config": {
        "sort-packages": true,
        "optimize-autoloader": true
    },
    "minimum-stability": "stable",
    "scripts": {
      "php-cs-fixer": "vendor/bin/php-cs-fixer --allow-risky=yes fix",
      "phpunit": "XDEBUG_MODE=coverage vendor/bin/phpunit --testdox",
      "phpstan": "vendor/bin/phpstan analyse src -c phpstan.neon"
    }
}
